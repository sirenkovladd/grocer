# LLM Configuration
LLM_PROVIDER=kimi
LLM_API_KEY=your-api-key-here
LLM_MODEL=kimi-k2.6

# GCloud Storage
GCS_BUCKET=your-bucket-name
GCS_PREFIX=snapshots/
GCS_CREDENTIALS_FILE=credentials.json

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=

# Discord Bot (optional)
DISCORD_BOT_TOKEN=

# Bot Web URL (for links in bot messages)
BOT_WEB_URL=http://localhost:8080

# Photo Cache
PHOTO_CACHE_DIR=./cache/photos
PHOTO_CACHE_SIZE=500

# Server
PORT=8080
