# LLM Configuration
LLM_PROVIDER=kimi
LLM_API_KEY=your-api-key-here
LLM_MODEL=kimi-k2.6

# GCloud Storage
GCS_BUCKET=your-bucket-name
GCS_PREFIX=snapshots/
GCS_CREDENTIALS_FILE=credentials.json

# GCP project (required for the Pub/Sub snapshot watcher; not used
# elsewhere). Find it with: gcloud config get-value project
GCP_PROJECT_ID=your-gcp-project-id

# Pub/Sub snapshot watcher (optional but recommended for multi-instance
# setups). See internal/store/pubsub.go for the one-time gcloud setup.
# Leave GCS_PUBSUB_TOPIC empty to disable the watcher; without it,
# instances only sync on restart.
GCS_PUBSUB_TOPIC=
GCS_PUBSUB_SUBSCRIPTION=  # optional; defaults to grocer-snapshot-watcher-<hostname>

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=

# Discord Bot (optional)
DISCORD_BOT_TOKEN=

# Bot Web URL (for links in bot messages)
BOT_WEB_URL=http://localhost:8080

# Photo Cache
PHOTO_CACHE_DIR=./cache/photos
PHOTO_CACHE_SIZE=500

# Server
PORT=8080
